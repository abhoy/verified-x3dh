#!/usr/bin/env bash
set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${X3DH_VERIFY_CONFIG:-$SCRIPT_DIR/.x3dh_verify.env}"
MAKEFILE_URL="https://gist.githubusercontent.com/W95Psp/4c304132a1f85c5af4e4959dd6b356c3/raw/Makefile"

is_sourced() {
  [[ "${BASH_SOURCE[0]}" != "$0" ]]
}

finish() {
  local code="${1:-0}"
  if is_sourced; then
    return "$code"
  fi
  exit "$code"
}

load_config() {
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
  fi

  HAX_ROOT="${HAX_ROOT:-}"
  EXTRACTION_DIR="${EXTRACTION_DIR:-$SCRIPT_DIR/proofs/fstar/extraction}"
  VENV_PATH="${VENV_PATH:-$SCRIPT_DIR/../venv}"
  FSTAR_BIN="${FSTAR_BIN:-fstar.exe}"
  OPAM_SWITCH="${OPAM_SWITCH:-}"
  LOAD_OPAM_ENV="${LOAD_OPAM_ENV:-1}"
  LOAD_VENV="${LOAD_VENV:-1}"

  export HAX_ROOT EXTRACTION_DIR VENV_PATH FSTAR_BIN OPAM_SWITCH LOAD_OPAM_ENV LOAD_VENV
}

activate_env() {
  load_config
  cd "$SCRIPT_DIR" || finish 1

  if [[ "$LOAD_VENV" == "1" && -f "$VENV_PATH/bin/activate" ]]; then
    # shellcheck disable=SC1090
    source "$VENV_PATH/bin/activate"
  fi

  if [[ "$LOAD_OPAM_ENV" == "1" ]] && command -v opam >/dev/null 2>&1; then
    if [[ -n "$OPAM_SWITCH" ]]; then
      eval "$(opam env --switch "$OPAM_SWITCH" --set-switch)"
    else
      eval "$(opam env)"
    fi
  fi

  if [[ -z "$HAX_ROOT" ]]; then
    echo "HAX_ROOT is not configured."
    echo "Set it in $CONFIG_FILE or export HAX_ROOT=/path/to/hax."
    finish 1
  fi

  if [[ ! -d "$HAX_ROOT" ]]; then
    echo "Configured HAX_ROOT does not exist: $HAX_ROOT"
    finish 1
  fi

  FSTAR_INCLUDES=(
    --include "$HAX_ROOT/proof-libs/fstar/core"
    --include "$HAX_ROOT/proof-libs/fstar/rust_primitives"
    --include "$HAX_ROOT/hax-lib/proofs/fstar/extraction"
    --include "$EXTRACTION_DIR"
  )
}

ensure_crate_setup() {
  local extraction_root="$SCRIPT_DIR/proofs/fstar/extraction"
  local makefile_path="$extraction_root/Makefile"
  local cargo_toml="$SCRIPT_DIR/Cargo.toml"

  mkdir -p "$extraction_root"

  if [[ ! -f "$makefile_path" ]]; then
    if ! command -v curl >/dev/null 2>&1; then
      echo "Missing curl; cannot fetch $makefile_path"
      return 1
    fi

    echo "Fetching F* extraction Makefile"
    curl -o "$makefile_path" "$MAKEFILE_URL" || return 1
  fi

  if [[ ! -f "$cargo_toml" ]]; then
    echo "Missing Cargo.toml in $SCRIPT_DIR"
    return 1
  fi

  if ! grep -q "hax-lib" "$cargo_toml"; then
    echo "Adding hax-lib dependency for cfg(hax)"
    cargo add --target 'cfg(hax)' --git https://github.com/hacspec/hax hax-lib || return 1
  fi
}

CORE_CHAIN=(
  "Verified_x3dh.Types.fst"
  "Verified_x3dh.Transcript.fst"
  "Verified_x3dh.Kdf.fst"
)

HANDSHAKE_CHAIN=(
  "${CORE_CHAIN[@]}"
  "Verified_x3dh.Ad.fst"
  "Verified_x3dh.Handshake_core.fst"
)

STATE_CHAIN=(
  "${HANDSHAKE_CHAIN[@]}"
  "Verified_x3dh.State.fst"
)

FULL_PROTOCOL_CHAIN=(
  "${STATE_CHAIN[@]}"
  "Verified_x3dh.Properties.fst"
)

verify_fstar() {
  local verify_mode="$1"
  local files_to_verify=()

  case "$verify_mode" in
    verify-none)
      echo "Skipping F* verification."
      return 0
      ;;
    verify-all|"")
      files_to_verify=("${FULL_PROTOCOL_CHAIN[@]}")
      ;;
    verify-transcript)
      files_to_verify=("Verified_x3dh.Types.fst" "Verified_x3dh.Transcript.fst")
      ;;
    verify-kdf)
      files_to_verify=("${CORE_CHAIN[@]}")
      ;;
    verify-ad)
      files_to_verify=("Verified_x3dh.Types.fst" "Verified_x3dh.Ad.fst")
      ;;
    verify-handshake)
      files_to_verify=("${HANDSHAKE_CHAIN[@]}")
      ;;
    verify-state)
      files_to_verify=("${STATE_CHAIN[@]}")
      ;;
    verify-properties)
      files_to_verify=("${FULL_PROTOCOL_CHAIN[@]}")
      ;;
    verify-make-lax)
      ensure_crate_setup || return 1
      if ! command -v make >/dev/null 2>&1; then
        echo "Missing make; required for Makefile-based F* verification."
        return 1
      fi
      echo
      echo "Running Makefile-based F* lax check"
      (
        cd "$EXTRACTION_DIR"
        OTHERFLAGS="--lax" make
      )
      return $?
      ;;
    verify-make)
      ensure_crate_setup || return 1
      if ! command -v make >/dev/null 2>&1; then
        echo "Missing make; required for Makefile-based F* verification."
        return 1
      fi
      echo
      echo "Running Makefile-based F* full typecheck"
      (
        cd "$EXTRACTION_DIR"
        make
      )
      return $?
      ;;
    verify-make-all)
      ensure_crate_setup || return 1
      if ! command -v make >/dev/null 2>&1; then
        echo "Missing make; required for Makefile-based F* verification."
        return 1
      fi
      echo
      echo "Running Makefile-based F* lax check"
      (
        cd "$EXTRACTION_DIR"
        OTHERFLAGS="--lax" make
      ) || return 1
      echo
      echo "Running Makefile-based F* full typecheck"
      (
        cd "$EXTRACTION_DIR"
        make
      )
      return $?
      ;;
    *)
      echo "Unknown verification mode: $verify_mode"
      return 1
      ;;
  esac

  echo
  echo "Verifying F* files using mode: ${verify_mode:-verify-all}"

  if ! command -v "$FSTAR_BIN" >/dev/null 2>&1; then
    echo "Missing F* binary: $FSTAR_BIN"
    echo "Set FSTAR_BIN in $CONFIG_FILE or ensure it is on PATH."
    return 1
  fi

  for file in "${files_to_verify[@]}"; do
    local path="$EXTRACTION_DIR/$file"
    if [[ -f "$path" ]]; then
      echo "Verifying $file"
      "$FSTAR_BIN" "${FSTAR_INCLUDES[@]}" "$path" || return 1
    else
      echo "Skipping missing file: $path"
    fi
  done
}

run_extraction() {
  local mode="$1"
  local verify_mode="$2"

  case "$mode" in
    verify-only)
      echo "Running verification only (no extraction)"
      verify_fstar "$verify_mode"
      return $?
      ;;
    all)
      ensure_crate_setup || return 1
      echo "Running full extraction..."
      cargo hax into fstar || return 1
      ;;
    partial)
      ensure_crate_setup || return 1
      local param="${3:-}"
      if [[ -z "$param" ]]; then
        echo "Missing partial extraction parameter."
        return 1
      fi
      echo "Running partial extraction for: $param"
      cargo hax into -i "-** $param" fstar || return 1
      ;;
    transcript)
      ensure_crate_setup || return 1
      echo "Transcript module"
      cargo hax into -i "-** +verified_x3dh::transcript::*" fstar || return 1
      ;;
    kdf)
      ensure_crate_setup || return 1
      echo "KDF module"
      cargo hax into -i "-** +verified_x3dh::kdf::*" fstar || return 1
      ;;
    ad)
      ensure_crate_setup || return 1
      echo "AD module"
      cargo hax into -i "-** +verified_x3dh::ad::*" fstar || return 1
      ;;
    handshake)
      ensure_crate_setup || return 1
      echo "Handshake core"
      cargo hax into -i "-** +verified_x3dh::handshake_core::*" fstar || return 1
      ;;
    state)
      ensure_crate_setup || return 1
      echo "State module"
      cargo hax into -i "-** +verified_x3dh::state::*" fstar || return 1
      ;;
    properties)
      ensure_crate_setup || return 1
      echo "Properties module"
      cargo hax into -i "-** +verified_x3dh::properties::*" fstar || return 1
      ;;
    core)
      ensure_crate_setup || return 1
      echo "Core protocol"
      cargo hax into -i "-** +verified_x3dh::handshake_core::* +verified_x3dh::kdf::* +verified_x3dh::transcript::*" fstar || return 1
      ;;
    crypto)
      ensure_crate_setup || return 1
      echo "Crypto/KDF"
      cargo hax into -i "-** +verified_x3dh::kdf::*" fstar || return 1
      ;;
    minimal)
      ensure_crate_setup || return 1
      echo "Minimal extraction"
      cargo hax into -i "-** +verified_x3dh::handshake_core::alice_initiate_core +verified_x3dh::handshake_core::bob_receive_core" fstar || return 1
      ;;
    env)
      echo "Environment ready"
      return 0
      ;;
    help|"")
      show_help
      return 0
      ;;
    *)
      echo "Unknown command: $mode"
      return 1
      ;;
  esac

  verify_fstar "$verify_mode"
}

show_help() {
  cat <<EOF
Usage:
  ./verify_x3dh <mode> [verification-mode]

Modes:
  env
  all
  transcript
  kdf
  ad
  handshake
  state
  properties
  core
  crypto
  minimal
  partial '+verified_x3dh::module::item'
  verify-only [verification-mode]

Verification modes:
  verify-all
  verify-none
  verify-kdf
  verify-transcript
  verify-ad
  verify-handshake
  verify-state
  verify-properties
  verify-make-lax
  verify-make
  verify-make-all

Config file:
  $CONFIG_FILE

Examples:
  ./verify_x3dh all verify-all
  ./verify_x3dh all verify-make-all
  ./verify_x3dh kdf verify-kdf
  ./verify_x3dh handshake verify-handshake
  ./verify_x3dh verify-only verify-make-lax
  ./verify_x3dh partial '+verified_x3dh::kdf::x3dh_kdf' verify-kdf
EOF
}

main() {
  local mode="${1:-help}"
  local verify_mode="${2:-verify-all}"
  local partial_param="${3:-}"

  activate_env

  if [[ "$mode" == "help" || -z "$mode" ]]; then
    show_help
    finish 0
  fi

  if ! run_extraction "$mode" "$verify_mode" "$partial_param"; then
    finish 1
  fi

  echo
  echo "Done"
  finish 0
}

main "$@"
